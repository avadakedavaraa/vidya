{
  "name": "vidyasetu-backend",
  "version": "1.0.0",
  "description": "Vidyasetu backend — Supabase Edge Functions + migrations",
  "private": true,
  "scripts": {
    "link":       "supabase link --project-ref qnyvnenfgavuookqsbom",
    "migrate":    "echo 'Run SQL files manually in Supabase Dashboard → SQL Editor'",
    "deploy":     "npm run deploy:all",
    "deploy:all": "npm run deploy:send-otp && npm run deploy:verify-otp && npm run deploy:book-session && npm run deploy:complete-session && npm run deploy:post-bounty && npm run deploy:submit-bid && npm run deploy:claim-quest && npm run deploy:release-escrow",
    "deploy:send-otp":         "supabase functions deploy send-otp --no-verify-jwt",
    "deploy:verify-otp":       "supabase functions deploy verify-otp --no-verify-jwt",
    "deploy:book-session":     "supabase functions deploy book-session",
    "deploy:complete-session": "supabase functions deploy complete-session",
    "deploy:post-bounty":      "supabase functions deploy post-bounty",
    "deploy:submit-bid":       "supabase functions deploy submit-bid",
    "deploy:claim-quest":      "supabase functions deploy claim-quest",
    "deploy:release-escrow":   "supabase functions deploy release-escrow --no-verify-jwt",
    "secrets": "supabase secrets set RESEND_API_KEY=$RESEND_API_KEY CRON_SECRET=$CRON_SECRET",
    "logs:send-otp":     "supabase functions logs send-otp --tail",
    "logs:verify-otp":   "supabase functions logs verify-otp --tail",
    "logs:book-session": "supabase functions logs book-session --tail",
    "start":  "supabase start",
    "stop":   "supabase stop",
    "status": "supabase status"
  },
  "devDependencies": {
    "supabase": "^1.200.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
